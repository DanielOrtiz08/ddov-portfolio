NEXT_PUBLIC_GITHUB_USERNAME=
NEXT_PUBLIC_LINKEDIN_URL=

# Email (Resend)
# Create a free account at https://resend.com and get an API key
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_OWNER_EMAIL=your-email@example.com

# If you're using a Resend test API key:
# - only authorized recipients can receive emails
# - verify your sending domain at https://resend.com/domains
# - or add the recipient email in your Resend dashboard
#
# WhatsApp notification service: 'twilio' | 'telegram' | 'webhook'
WHATSAPP_SERVICE=twilio
WHATSAPP_PHONE=1234567890

# Twilio (WhatsApp) - optional (recommended for real WhatsApp messages)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+1415XXXXXXX
# Optional: use these only if you want to send a Twilio WhatsApp template message.
# If empty, the backend sends a normal text message in Body.
TWILIO_WHATSAPP_CONTENT_SID=
TWILIO_WHATSAPP_CONTENT_VARIABLES=

# Telegram (free alternative - sends a notification to a chat, not WhatsApp)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webhook: optional for services like n8n, Make or custom endpoints
WHATSAPP_WEBHOOK_URL=

# Redis (recommended for production anti-spam state)
# Example: REDIS_URL=rediss://:password@ec2-11-22-33-44.compute-1.amazonaws.com:6379
REDIS_URL=REDIS_URL=rediss://:TU_PRIMARY_KEY@TU_HOST:6380?ssl=true
